#!/usr/bin/env bash
#
# Test runner for /graph/summary
#
set -e

BRANE_ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
source "$BRANE_ROOT/tests/lib.sh"

INPUT=$(cat)
workspace

case "$TC_CASE_NAME" in
  00-success-basic-summary)
    init_mind
    create_concept '{"name": "AuthService", "type": "Entity"}'
    create_concept '{"name": "Database", "type": "Entity"}'
    create_concept '{"name": "MustAuth", "type": "Rule"}'
    create_edge '{"source": 1, "target": 2, "relation": "DEPENDS_ON"}'
    create_edge '{"source": 3, "target": 1, "relation": "APPLIES_TO"}'
    ;;
  01-success-empty-graph)
    init_mind
    # No concepts or edges
    ;;
  02-error-not-initialized)
    # Don't initialize
    ;;
esac

echo "$INPUT" | bun run "$BRANE_ROOT/src/cli.ts" /graph/summary
